# .env.example
# Copy to .env and fill in your values. The .env file is git-ignored.

# ── AWS ──────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_IAM_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_IAM_SECRET_KEY
AWS_REGION=us-east-2                 # match your Snowflake account region
S3_BUCKET_NAME=your-olist-bucket-name

# ── Snowflake ─────────────────────────────────────────────────────────────────
SNOWFLAKE_ACCOUNT=YOUR_ACCOUNT_LOCATOR   # e.g. IOAMFHY-SK55610 — no region suffix for newer accounts
SNOWFLAKE_USER=YOUR_USERNAME
SNOWFLAKE_PASSWORD=YOUR_PASSWORD
SNOWFLAKE_DATABASE=ECOMMERCE_DB
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_WAREHOUSE=ECOMMERCE_WH
SNOWFLAKE_ROLE=REPORTER
